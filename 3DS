    def powcast(self, value):
        try:
            new = []
            for i in self.l:
                new.append(i ** value)
            return Darray(new)
        except Exception:
            return self.l

    def __str__(self):
        return f'{self.l}'
    
    def __iter__(self):
        for i in self.l:
            yield i
    
    def __len__(self):
        return len(self.l)
    
    def __add__(self, other):
        return Darray(self.l + other.l)

    def __sub__(self, other):
        return Darray(self.l - other.l)
    
    def __mul__(self, value):
        return Darray(self.l * value)

    def __getitem__(self, index):
        if index == 0:
            raise IndexError('Darray indexing cannot have 0')
        return self.l[index - 1]
    
    def __contains__(self, value):
        return value in self.l

    def help():
        print('1 index system')

