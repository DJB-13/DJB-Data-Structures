class Drange:

    def __init__(self, start, end, step=1):
        self.start = start
        self.end = end
        self.step = step
        
    def __str__(self):
        l = []
        i = self.start
        while i <= self.end:
            l.append(i)
            i += self.step
        return f'{Darray(l)}'
    
    def __iter__(self):
        i = self.start
        while i <= self.end:
            yield round(i, 10)
            i += self.step

    def __reversed__(self):
        i = self.end
        while i >= self.start:
            yield round(i, 10)
            i -= self.step

    def randomized(self):
        import random
        l = []
        i = self.start
        while i <= self.end:
            l.append(i)
            i += self.step
        random.shuffle(l)
        return Darray(l)

    def midpoint(self):
        return (self.start + self.end) / 2
        
    def span(self):
        return self.end - self.start
    
    def noofiter(self):
        return int(round((self.end - self.start) / self.step, 10) + 1)

    def do(self, func):
        l = []
        i = self.start
        while i <= self.end:
            l.append(i)
            i += self.step
        new = [func(x) for x in l]
        return Darray(new)

    def apply(self, func):
        l = []
        i = self.start
        while i <= self.end:
            l.append(i)
            i += self.step
        new = [x for x in l if func(x)]
        return Darray(new)
